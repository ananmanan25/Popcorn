function goSlide(idx) {
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  if (!slides.length) return;
  slides[heroIdx]?.classList.remove('active');
  dots[heroIdx]?.classList.remove('active');
  heroIdx = (idx + slides.length) % slides.length;
  slides[heroIdx]?.classList.add('active');
  dots[heroIdx]?.classList.add('active');
}
window.nextSlide = () => { clearTimeout(heroTimer); goSlide(heroIdx + 1); startHeroTimer(); };
window.prevSlide = () => { clearTimeout(heroTimer); goSlide(heroIdx - 1); startHeroTimer(); };
function startHeroTimer() { heroTimer = setTimeout(() => { goSlide(heroIdx + 1); startHeroTimer(); }, 6000); }

// ── LOAD ──
async function loadVideos() {
  showSkeletons();
  try {
    const q = query(collection(db, 'videos'), orderBy('createdAt', 'desc'));
    const snap = await getDocs(q);
    allVideos = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  } catch(e) { console.error(e); }
  buildHero(allVideos);
  renderContent();
  hideLoader();
}

