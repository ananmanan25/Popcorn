  border:1px solid var(--border2);border-radius:11px;padding:13px 20px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.95rem;font-weight:600;transition:.2s;}
.modal-btn-list:hover{background:rgba(255,255,255,0.1);}

/* ─── EMPTY ─── */
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:100px 20px;color:var(--muted);text-align:center;gap:12px;}
.empty p{font-size:1.1rem;color:var(--text2);}
.empty small{font-size:.85rem;}

/* ─── SKELETONS ─── */
.skel-card{background:var(--card);border-radius:14px;overflow:hidden;border:1px solid var(--border);}
.skel-thumb{width:100%;aspect-ratio:16/10;background:linear-gradient(90deg,#111120 25%,#1a1a30 50%,#111120 75%);background-size:200% 100%;animation:shimmer 1.6s ease infinite;}
@keyframes shimmer{0%{background-position:200% 0;}100%{background-position:-200% 0;}}
.skel-line{height:12px;border-radius:6px;margin:12px 14px 5px;background:#1a1a30;}
.skel-line.short{width:55%;margin-top:4px;}

/* ─── FOOTER ─── */
footer{padding:50px 40px;border-top:1px solid var(--border);margin-top:30px;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px;}
.footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:3px;background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:12px;}
.footer-desc{color:var(--muted);font-size:.85rem;line-height:1.7;max-width:280px;}
.footer-head{font-weight:600;font-size:.87rem;color:var(--text);margin-bottom:14px;letter-spacing:.3px;}
.footer-links{display:flex;flex-direction:column;gap:10px;}
.footer-links a{color:var(--muted);font-size:.83rem;text-decoration:none;transition:.2s;}
.footer-links a:hover{color:var(--text);}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;padding-top:24px;border-top:1px solid var(--border);color:var(--muted);font-size:.8rem;}
.footer-badges{display:flex;gap:10px;}
.f-badge{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:6px;padding:4px 12px;font-size:.75rem;color:var(--muted2);}

/* ─── RESPONSIVE ─── */
@media(max-width:900px){
