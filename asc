function getFiltered() {
  return allVideos.filter(v => {
    const mc = currentCategory === 'all' || v.category === currentCategory;
    const ms = !searchQuery || v.title?.toLowerCase().includes(searchQuery) || v.description?.toLowerCase().includes(searchQuery);
    return mc && ms;
  });
}

const catIcons = {Action:'⚡',Comedy:'😂',Drama:'🎭',Horror:'👻',Documentary:'📹',Romance:'❤️',Thriller:'🔪',Animation:'🎨','Sci-Fi':'🚀',Fantasy:'🧙',Mystery:'🔍',Adventure:'🗺️',Uncategorized:'🎬'};

function renderContent() {
  const filtered = getFiltered();
  const c = document.getElementById('mainContent');

  if (!filtered.length) {
    c.innerHTML = `<div class="empty">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <p>No titles found</p>
      <small>${currentCategory !== 'all' ? 'Try a different genre or ' : ''}add content via the Admin panel.</small>
    </div>`;
    return;
  }

  if (currentCategory === 'all' && !searchQuery) {
    const groups = {};
    filtered.forEach(v => { const cat = v.category || 'Uncategorized'; if (!groups[cat]) groups[cat] = []; groups[cat].push(v); });

    let html = `<div class="section" id="content-top">
      <div class="sec-header">
        <div class="sec-title">🔥 <span class="accent">Featured</span> Now<div class="sec-line"></div></div>
      </div>
      <div class="featured-strip">${filtered.slice(0,3).map(featCard).join('')}</div>
    </div>`;

    html += `<div class="section">
      <div class="sec-header">
        <div class="sec-title">✨ <span class="accent">New</span> Releases<div class="sec-line"></div></div>
        <button class="see-all-btn" onclick="filterCategory('all')">See All <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,18 15,12 9,6"/></svg></button>
      </div>
      <div class="cards-grid">${filtered.slice(0,6).map(v=>videoCard(v,true)).join('')}</div>
    </div>`;

    Object.entries(groups).forEach(([cat, vids]) => {
      html += `<div class="section">
        <div class="sec-header">
          <div class="sec-title">${catIcons[cat]||'🎬'} <span class="accent">${cat}</span><div class="sec-line"></div></div>
          <button class="see-all-btn" onclick="filterCategory('${cat}')">All ${cat} (${vids.length}) <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,18 15,12 9,6"/></svg></button>
        </div>
        <div class="h-scroll-wrap"><div class="h-scroll">${vids.slice(0,10).map(v=>videoCard(v)).join('')}</div></div>
      </div>`;
    });

    c.innerHTML = html;
  } else {
    c.innerHTML = `<div class="section" id="content-top">
      <div class="sec-header">
        <div class="sec-title">${catIcons[currentCategory]||'🎬'} <span class="accent">${currentCategory==='all'?'All Titles':currentCategory}</span>${searchQuery?` · "${searchQuery}"`:''}
        <div class="sec-line"></div></div>
        <span style="color:var(--muted);font-size:.82rem">${filtered.length} title${filtered.length!==1?'s':''}</span>
      </div>
      <div class="cards-grid">${filtered.map(v=>videoCard(v)).join('')}</div>
    </div>`;
  }
}

function featCard(v) {
  return `<div class="feat-card" onclick="openModal('${v.id}')">
    ${v.thumbnailUrl ? `<img class="feat-img" src="${v.thumbnailUrl}" loading="lazy" alt="${v.title||''}"/>` : `<div class="feat-ph"></div>`}
    <div class="feat-overlay">
      <div class="feat-cat">${v.category||'General'}</div>
      <div class="feat-name">${v.title||'Untitled'}</div>
      <div class="feat-row">
        <span>▶ Watch</span>
        ${v.duration?`<span>⏱ ${v.duration}</span>`:''}
        <div class="feat-play-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="#000"><polygon points="5,3 19,12 5,21"/></svg></div>
      </div>
    </div>
  </div>`;
}

function videoCard(v, isNew) {
  return `<div class="v-card" onclick="openModal('${v.id}')">
    <div class="v-thumb">
      ${v.thumbnailUrl
        ? `<img src="${v.thumbnailUrl}" loading="lazy" alt="${v.title||''}" style="width:100%;height:100%;object-fit:cover;display:block;"/>`
        : `<div class="v-ph"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"><polygon points="5,3 19,12 5,21"/></svg></div>`}
      <div class="v-hover-layer"><div class="v-play-ring"><svg width="17" height="17" viewBox="0 0 24 24" fill="#000"><polygon points="5,3 19,12 5,21"/></svg></div></div>
      ${isNew?`<div class="new-tag">NEW</div>`:''}
    </div>
    <div class="v-body">
      <div class="v-genre">${v.category||'General'}</div>
      <div class="v-title">${v.title||'Untitled'}</div>
      <div class="v-meta">
        ${v.duration?`<span class="v-dur"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>${v.duration}</span>`:''}
        ${v.year?`<span class="v-dot"></span><span>${v.year}</span>`:''}
      </div>
    </div>
  </div>`;
}

window.openModal = function(id) {
  const v = allVideos.find(x => x.id === id);
  if (!v) return;
  document.getElementById('modalTitle').textContent = v.title || 'Untitled';
  document.getElementById('modalDesc').textContent = v.description || 'No description available.';
  document.getElementById('modalTags').innerHTML = [v.category, v.duration, v.year].filter(Boolean).map(t=>`<span class="modal-tag">${t}</span>`).join('');
  const vid = document.getElementById('modalVideo');
  vid.src = v.videoUrl || '';
  vid.load();
  document.getElementById('modalWrap').classList.add('open');
  document.body.style.overflow = 'hidden';
};

window.closeModal = function(e) { if (e.target === document.getElementById('modalWrap')) closeModalBtn(); };
window.closeModalBtn = function() {
  document.getElementById('modalWrap').classList.remove('open');
  const v = document.getElementById('modalVideo');
  v.pause(); v.src = '';
  document.body.style.overflow = '';
};

// Keyboard close
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModalBtn(); });

loadVideos();
</script>
</body>
</html>
